    // su isnt used anymore
    function getPlayerData(id, su)
    {
        var player = players.find(x => x.id == id);
        var playerID = $("#playerID" + su);
        var playerLabel = $("#playerName" + su + " > label");
        var playerName = $('#playerName' + su + ' > input');
        var fRating = $('#playerRating' + su + ' > input');
        var fBday = $('#playerbday' + su + ' > input');
        var fteam = $('#playerteam' + su + ' > input');
        var fSalary = $('#playerSalary' + su + ' > input');

        var playerRating = player.rating;
        var playerBday = new Date(player.birthDate);
        var playerTeam = player.team;
        var playerSalary = player.salary;
        var bdaystring = playerBday.toISOString().slice(0, 10);


        playerID.val(id);
        playerName.val(player.name);
        fRating.val(playerRating);
        fBday.val(bdaystring);
        fteam.val(playerTeam);
        fSalary.val(playerSalary);

        currId = id;
    }

    // fills the player data when entering the delete modal, through
    // a call to getItemIndex
    function fillDelPid(id)
    {
        var fDelPid = $("#delPlayerId");

        fDelPid.val(id);
        getItemIndex(id, 'Delete');
    }

    // takes a database id (passed from html, or a preceding method)
    // and attaches the data associated with the id to a form using
    // dd / dt tags

    function getItemIndex(id, form)
    {
        var player = players.find(x => x.id == id);
        var formStr = "#detailsForm" + form;
        var detailsDD = $(formStr + ' > dd');
        detailsDD[0].innerHTML = player.name;
        detailsDD[1].innerHTML = player.rating;
        detailsDD[2].innerHTML = player.birthDate.slice(0,10);
        detailsDD[3].innerHTML = player.team;
        detailsDD[4].innerHTML = player.salary;
    }

    // unused 
    // DELETE WHEN CLEANING UP

    function getEditData(id) {
        var playerName = $('#playerName > input')
        var fRating = $('#playerRating > input')
        var fBday = $('#playerbday > input')
        var fteam = $('#playerteam > input')
        var fSalary = $('#playerSalary > input')

        pData.name = playerName.val();
        pData.Rating = fRating.val();
        pData.birthDate = fBday.val();
        pData.team = fteam.val();
        pData.salary = fSalary.val();

    }

    // UNUSED DELETE
    function submitEdit() {

        getEditData(currId)
        // do people actually like the ajax syntax???

        console.log("pData object right before AJAX call: ")
        console.log(pData)
        $.ajax({
            url: "@Url.Action("SubmitEdit", "Players")",
            type: 'post',
            data: {id: pData.id, player: pData},
            success: function (result) {
                console.log('success')
            },
            error: function (result) {
                console.log(result)
            }
        })

        return false;
    }


    // fills the LeagueID input field (hidden) in the create
    // view to the current operating ID (default is NHL's id)
    function fillPlayerLeagueID(id)
    {
        var idField = $('#playerLeagueID');
        idField.val(id);
    }

    // snippet i got this from calls them 'URIs' -- archaic
    var playersUri = '/api/players/'; // call them URLs, not uri


    // calls the ajaxhelper method with GET method, accepts a call back
    // parameter but doesn't do anything -- edit out later
    function getAllPlayers(callback) {

        // this is the most frustrating interface i have ever used
        ajaxHelper(playersUri, 'GET').done(cb);
    }

    // With ajax, we can't guarantee the players object will be filled
    // by the time the page loads, so disabling the edit buttons kind of
    // works around that

    // callback for the ajax helper method (see jQuery done() method docs)
    // this calls after the ajax succeeds
    function cb(data) {
        players = data;
        $('.edit').prop('disabled', false);
    }
</script>
