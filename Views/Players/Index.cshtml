@model WebApplication1.Models.PlayerTeamViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var leagues = ViewData["Leagues"] as List<League>;
    int index = 0;

    // barf
    var routeID = ViewData["ID"];
}



<div class="sidenav" id="left_sidenav">
    <a class="expandbtn" onclick="hideNav('left_sidenav')">&#9776;</a>
    <a class="closebtn" href="javascript:void(0)" onclick="hideNav('left_sidenav')">&#10005;</a>
    @foreach(var item in leagues)
    {
        <a asp-controller="Players" asp-action="Index" asp-route-id="@item.LeagueID">
            @Html.DisplayFor(modelItem => item.Name)
        </a>
    }
    @*<a asp-controller="Players" asp-action="Index" asp-route-id="1">NHL</a>
    <a asp-controller="Players" asp-action="Index" asp-route-id="2">NBA</a>
    <a asp-controller="Players" asp-action="Index" asp-route-id="3">MLB</a>
    <a asp-controller="Players" asp-action="Index" asp-route-id="4">NFL</a>*@
    @*<button class="btn btn-primary" onclick="hideNav('left_sidenav')">Test Hide</button>*@
</div>

<p>
    @* The syntax for toggling modals is so weird *@
    <button type="button" class="btn btn-primary" data-target="#createModal" data-toggle="modal" onclick="fillPlayerLeagueID(@routeID)">Create New</button>
</p>
<form asp-controller="Players" asp-action="Index" method="get">
    <p>
        <select asp-for="PlayerTeam" asp-items="Model.Teams">
            <option value="">All</option>
        </select>

        Name: <input type="text" name="SearchString" />
        <input type="submit" value="filter" />
    </p>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Player.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Player.BirthDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Player.Team)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Player.Salary)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Player.Rating)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Players)
        {

            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.BirthDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Team)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Salary)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Rating)
                </td>
                <td>
                    <form>
                        <button type="button" data-toggle="modal" data-target="#exampleModal" class="edit btn-primary btn" asp-route-id="10" onclick="getPlayerData(@item.Id,'')" disabled>Edit</button> |
                        <button type="button" class="edit btn-primary btn" data-toggle="modal" data-target="#detailsModal" asp-route-id="@item.Id" onclick="getItemIndex(@item.Id, '')" disabled>Details</button> |
                        <button type="button" data-toggle="modal" data-target="#deleteModal" class="edit btn-primary btn" asp-route-id="@item.Id" onclick="fillDelPid(@item.Id)" disabled>Delete</button>
                    </form>
                    @*<a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>*@
                </td>
            </tr>
            index++;
        }
        @{index--; }
    </tbody>
</table>
<!-- Button trigger modal -->
@*<button type="button" class="btn btn-primary" data-toggle="modal" data-target="#exampleModal">
        Launch demo modal
    </button>*@

<div class="modal fade" id="createModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createModalLabel">Create New Player</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="Create">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">

                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <input id="playerLeagueID" type="hidden" asp-for="Player.LeagueID" />
                            <div id="playerNameCreate" class="form-group">
                                <label asp-for="Player.Name" class="control-label"></label>
                                <input asp-for="Player.Name" class="form-control" />
                                <span asp-validation-for="Player.Name" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Player.Rating" class="control-label"></label>
                                <input asp-for="Player.Rating" class="form-control" />
                                <span asp-validation-for="Player.Rating" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Player.BirthDate" class="control-label"></label>
                                @*added type = date to ensure dynamic control, no reason for this not to be included...*@
                                <input type="date" asp-for="Player.BirthDate" class="form-control" />
                                <span asp-validation-for="Player.BirthDate" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Player.Team" class="control-label"></label>
                                <input asp-for="Player.Team" class="form-control" />
                                <span asp-validation-for="Player.Team" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Player.Salary" class="control-label"></label>
                                <input asp-for="Player.Salary" class="form-control" />
                                <span asp-validation-for="Player.Salary" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                @*<input type="submit" value="Save" class="btn btn-primary" />*@
                            </div>

                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Modal -->
